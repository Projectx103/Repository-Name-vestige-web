# ------------------------------------------------------------------------------
# VESTIGE — Environment Configuration Template
# Copy to .env.development / .env.staging / .env.production and fill in real
# values for that environment. NEVER commit a filled-in .env file (see .gitignore).
#
# Per 11 - Security.md §12 and 21 - Frontend Architecture.md §10: everything in
# this file is a public, non-secret client-side config value. Firebase's client
# config is safe to expose (security is enforced by Firestore Security Rules,
# not by hiding these values). No true secret (Cloudinary API secret, payment
# gateway secret key, etc.) EVER belongs in a frontend env var, in this file or
# any other.
# ------------------------------------------------------------------------------

# Which environment this build targets: development | staging | production
VITE_APP_ENV=development

# --- Firebase client config (per-environment project, 00 - Project Constitution.md §20) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Firebase Analytics — approved stack addition (not in the original Constitution
# list, added on explicit instruction). Analytics only initializes in the
# browser when this is set and emulators are off (see lib/firebase/config.ts).
VITE_FIREBASE_MEASUREMENT_ID=

# Set to "true" to connect to the local Firebase Emulator Suite instead of the
# live project named above (local development only).
VITE_USE_FIREBASE_EMULATORS=false

# --- Cloudinary (cloud name + unsigned-preset name only — never the API secret) ---
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
